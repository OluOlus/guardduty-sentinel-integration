{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "workspaceName": {
      "value": "sentinel-dev-workspace"
    },
    "guardDutyTableName": {
      "value": "AWSGuardDuty"
    },
    "rawDataColumn": {
      "value": "EventData"
    },
    "alternateRawDataColumn": {
      "value": "Message"
    },
    "defaultLookback": {
      "value": "1d"
    },
    "maxLookback": {
      "value": "30d"
    },
    "enableGeoEnrichment": {
      "value": true
    },
    "enableASIMNormalization": {
      "value": true
    },
    "enableDataValidation": {
      "value": true
    },
    "environment": {
      "value": "dev"
    }
  }
}